# Copy this file to .env.local and fill in your values.
# Next.js only reads .env.local from THIS directory (apps/www/), not the repo root.

# ── Liveblocks ────────────────────────────────────────────────────────────────
# Liveblocks is optional and OFF by default.
NEXT_PUBLIC_ENABLE_LIVEBLOCKS=false

# To enable multiplayer, set this to true and configure one auth mode below.
# NEXT_PUBLIC_ENABLE_LIVEBLOCKS=true

# Option A (recommended): private secret key — uses /api/liveblocks-auth
# LIVEBLOCKS_SECRET_KEY=sk_...

# Option B: public key — skips the auth endpoint entirely
# NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_API_KEY=pk_...
# NEXT_PUBLIC_LIVEBLOCKS_USE_PUBLIC_KEY=true

# ── Google Fonts (optional) ───────────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_FONTS_API_KEY=AIza...
